set -e -u -o pipefail


__get_afs_name_details() {
    pts examine -nameorid "$1" | \
      head -n 1 | sed 's/,[ \t]*$//' | \
      jq --raw-input --sort-keys 'ascii_downcase | split(", ") | map(split(": ")) | map({(.[0] | .): (.[1] | tonumber? // .)}) | add'
}


__get_afs_owned_list() {
    pts listowned -nameorid "$1" | \
      tail -n +2 | \
      sed 's/^[ \t]*//' | \
      jq --raw-input --null-input '[inputs] | sort'

}


__get_afs_membership_list() {
    pts membership -nameorid "$1" | \
      tail -n +2 | \
      sed 's/^[ \t]*//' | \
      jq --raw-input --null-input '[inputs] | sort'
}


__is_afs_user_id() {
    if (( "$1" > 0)); then

        return 0
    else
        return 1
    fi
}


__is_afs_group_id() {
    if (( "$1" > 0)); then
        return 1
    else
        return 0
    fi
}


__get_afs_membership_user_list() {
    local -a users
    while read -r afs_name; do
        local afs_name_clean=$(echo $afs_name | xargs)
        local afs_id=$(__get_afs_name_details $afs_name_clean | jq '.id')
        if __is_afs_user_id $afs_id; then
            users+=($afs_name_clean)
        fi
    done < <(__get_afs_membership_list "$1" | jq --compact-output '.[]')

    echo ${users[@]} | jq --raw-input 'split(" ") | sort'
}


__get_afs_membership_group_list() {
    local -a users
    while read -r afs_name; do
        local afs_name_clean=$(echo $afs_name | xargs)
        local afs_id=$(__get_afs_name_details $afs_name_clean | jq '.id')
        if __is_afs_group_id $afs_id; then
            users+=($afs_name_clean)
        fi
    done < <(__get_afs_membership_list "$1" | jq --compact-output '.[]')

    echo ${users[@]} | jq --raw-input 'split(" ") | sort'
}


__get_afs_owned_user_list() {
    local -a users
    while read -r afs_name; do
        local afs_name_clean=$(echo $afs_name | xargs)
        local afs_id=$(__get_afs_name_details $afs_name_clean | jq '.id')
        if __is_afs_user_id $afs_id; then
            users+=($afs_name_clean)
        fi
    done < <(__get_afs_owned_list "$1" | jq --compact-output '.[]')

    echo ${users[@]} | jq --raw-input 'split(" ") | sort'
}


__get_afs_owned_group_list() {
    local -a users
    while read -r afs_name; do
        local afs_name_clean=$(echo $afs_name | xargs)
        local afs_id=$(__get_afs_name_details $afs_name_clean | jq '.id')
        if __is_afs_group_id $afs_id; then
            users+=($afs_name_clean)
        fi
    done < <(__get_afs_owned_list "$1" | jq --compact-output '.[]')

    echo ${users[@]} | jq --raw-input 'split(" ") | sort'
}


__get_afs_users_recursive() {
    local -a array_tmpusr
    local -a array_tmpgrp

    local -A user_dict

    readarray -t array_tmpusr < <(__get_afs_membership_user_list "$1" | jq --raw-output '.[]')
    user_dict["$1"]=${array_tmpusr[@]}

    readarray -t array_tmpgrp < <(__get_afs_owned_group_list "$1" | jq --raw-output '.[]')
    for afs_group in ${array_tmpgrp[@]}
    do
        readarray -t array_tmpusr < <(__get_afs_membership_user_list $afs_group | jq --raw-output '.[]')
        user_dict[${afs_group}]=${array_tmpusr[@]}
    done

    local -a args
    for key in "${!user_dict[@]}"
    do
        args+=(--arg "$key" "${user_dict[$key]}")
    done
    jq --sort-keys --null-input "${args[@]}" '$ARGS.named | map_values(split(" "))'
}


__usage() {
    cat <<EOF
Usage: afs-mem <command> <name-or-id>

Commands:
  name-details
  owned-list
  membership-list
  membership-user-list
  membership-group-list
  owned-user-list
  owned-group-list
  users-recursive
EOF
}

if [[ $# -lt 2 ]]; then
    __usage
    exit 1
fi

AFS_ITEM="$1"

case $AFS_ITEM in
    "name-details")
        __get_afs_name_details "$2"
        ;;
    "owned-list")
        __get_afs_owned_list "$2"
        ;;
    "membership-list")
        __get_afs_membership_list "$2"
        ;;
    "membership-user-list")
        __get_afs_membership_user_list "$2"
        ;;
    "membership-group-list")
        __get_afs_membership_group_list "$2"
        ;;
    "owned-user-list")
        __get_afs_owned_user_list "$2"
        ;;
    "owned-group-list")
        __get_afs_owned_group_list "$2"
        ;;
    "users-recursive")
        __get_afs_users_recursive "$2"
        ;;
    *)
        __usage
        exit 2
        ;;
esac

set -e -u -o pipefail


__parse_afsacl_single_line() {
  local input="$1"

  local path_curr=$(echo "$input" | grep -oP '(?<=-dir )[^ ]+')

  local type_acl="normal"
  [[ "$input" =~ "-negative" ]] && type_acl="negative"

  local acl_part=$(echo "$input" | sed 's/.*-acl //; s/ -negative//' | xargs)

  echo "$acl_part" | jq --raw-input --arg p "$path_curr" --arg t "$type_acl" 'split(" +"; "") | [ range(0; length
; 2) as $i | { group: .[$i], authorizations: .[$i+1], type: ($t) } ] | { ($p): . }'
}


__get_afsacl_json() {
  local target_path="$1"
  local json_stream=""

  while IFS= read -r line; do
    local parsed_line=$(__parse_afsacl_single_line "$line")

    if [[ -n "$parsed_line" ]]; then
      json_stream+="${parsed_line}"$'\n'
    fi
  done < <(fs listacl -path "$target_path" -cmd 2>/dev/null)

  echo "$json_stream" | jq -s '
    reduce .[] as $item ({};
      reduce ($item | keys[]) as $key (.;
        .[$key] += $item[$key]
      )
    )
  '
}


__usage() {
    cat <<EOF
Usage: afs-acl <command> [args...]

Commands:
  path <path> [<path> ...]
EOF
}

if [[ $# -lt 2 ]]; then
    __usage
    exit 1
fi

AFS_ITEM="$1"

case $AFS_ITEM in
    "path")
        shift
        if [[ $# -eq 0 ]]; then
            __usage
            exit 1
        fi
        paths=("$@")
        for path in "${paths[@]}"; do
            __get_afsacl_json "$path"
        done | jq -s 'add'
        ;;
    *)
        __usage
        exit 2
        ;;
esac
